generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                   String        @id @default(uuid())
  nome                 String
  email                String        @unique
  senha                String
  emailVerified        DateTime?
  verificationToken    String?
  resetPasswordToken   String?
  resetPasswordExpires DateTime?
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt
  role                 String        @default("MEMBER") // "HEAD" or "MEMBER"
  initialBalance       Float         @default(0)

  familyId String?
  family   Family? @relation(fields: [familyId], references: [id])

  cards        Card[]
  investments  Investment[]
  members      Member[]
  transactions Transaction[]

  @@map("usuarios")
}

model Family {
  id           String   @id @default(uuid())
  nome         String
  inviteCode   String   @unique @default(uuid())
  blockedMenus String?  @default("") // Comma-separated list of blocked menu keys
  createdAt    DateTime @default(now())
  users        User[]

  @@map("familias")
}

model Member {
  id           String        @id @default(uuid())
  nome         String
  usuarioId    String
  user         User          @relation(fields: [usuarioId], references: [id])
  transactions Transaction[]

  @@map("membros")
}

model Category {
  id           String        @id @default(uuid())
  nome         String
  tipo         String
  transactions Transaction[]

  @@map("categorias")
}

model Card {
  id           String        @id @default(uuid())
  nome         String
  limite       Float
  fechamento   Int
  vencimento   Int
  banco        String        @default("Outros")
  last4        String        @default("0000")
  usuarioId    String
  user         User          @relation(fields: [usuarioId], references: [id])
  transactions Transaction[]

  @@map("cartoes")
}

model Transaction {
  id              String   @id @default(uuid())
  descricao       String
  valor           Float
  data            String
  categoriaId     String
  membroId        String
  usuarioId       String
  tipo            String
  metodoPagamento String   @default("dinheiro")
  cartaoId        String?
  parcelaAtual    Int?
  parcelasTotais  Int?
  createdAt       DateTime @default(now())
  card            Card?    @relation(fields: [cartaoId], references: [id])
  category        Category @relation(fields: [categoriaId], references: [id])
  member          Member   @relation(fields: [membroId], references: [id])
  user            User     @relation(fields: [usuarioId], references: [id])

  @@map("transacoes")
}

model Setting {
  key   String @id
  value String

  @@map("configuracoes")
}

model Investment {
  id        String @id @default(uuid())
  descricao String
  valor     Float
  tipo      String
  usuarioId String
  meta      Float?
  user      User   @relation(fields: [usuarioId], references: [id])

  @@map("investimentos")
}
